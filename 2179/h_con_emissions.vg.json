{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "spacing": 45,
  "bounds": "full",
  "padding": {"top": 15, "left": 15, "right": 10, "bottom": 10},
  "hconcat": [
    {
  "data": {"url": "co-emissions-per-capita.csv"},
  "title": {"text":"Mean CO2 Emissions", "offset":18},
  "width": 250, 
  "height": 200, 
  "mark": {"type": "line"},
  "encoding": {
    "x": {"field": "Year", "type": "temporal"},
    "y": {"field": "CO2 emissions per capita", "type": "quantitative", "aggregate": "mean",
      "title": "Mean CO2 emissions (tonnes per person)"}
  }
},
{
  "description": "Donut chart to show the Emissions by Sector in 2025",
  "data": {"url": "sector_emissions.csv"},
  "mark": {"type": "arc", "innerRadius": 50, "tooltip": true},
  "title": {"text": "Emissions by Sector", "offset":25},
  "encoding": {
    "theta": {"field": "Emissions", "type": "quantitative", "stack": "normalize"},
    "color": {"field": "Sector", "type": "nominal","scale": {
        "domain": [
          "Agriculture",
          "Electricity",
          "Fugitive Emissions",
          "Industrial Processes",
          "Stationary Energy",
          "Transport",
          "Waste"
        ],
        "range": [
          "#006A4E",
          "#1D4E89",
          "#7BA05B",
          "#1D3557",
          "#0077B6",
          "#54B9DD",
          "#828282"
        ]
      }
    }
  }
}], "config": {
    "view": {"stroke": null},
    "title": {"font": "sans-serif", "fontSize": 14, "anchor":"middle"}
  }
}